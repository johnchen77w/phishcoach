# Copy to .env and fill in. .env is gitignored.

# Anthropic
ANTHROPIC_API_KEY=

# Langfuse (or LangSmith — pick one)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Model selection — override if testing alternates
AUTHOR_MODEL=claude-sonnet-4-6
COACH_MODEL=claude-opus-4-7
JUDGE_MODEL=claude-opus-4-7

# Session
MAX_ROUNDS=8
CHECKPOINT_DB=./state/checkpoints.db
